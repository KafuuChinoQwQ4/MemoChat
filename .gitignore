# ---- Sensitive files (must ignore *.key/*.pfx, keep only checked-in certs) ----
/.secrets/
*.key
*.pfx
*.pem
# Keep only the source-tree cert/key pairs (NOT the runtime/ generated ones)
!/server/GateServerDrogon/server.crt
!/server/GateServerDrogon/server.key
!/server/GateServer/server.crt
!/server/GateServer/server.key

# Runtime-generated certs and keys (auto-generated at startup, never commit)
Memo_ops/runtime/services/GateServer/server.crt
Memo_ops/runtime/services/GateServer/server.key
Memo_ops/runtime/services/GateServer/server.pfx
Memo_ops/runtime/services/GateServerDrogon/server.crt
Memo_ops/runtime/services/GateServerDrogon/server.key
Memo_ops/runtime/services/GateServerDrogon/server.pfx

# Runtime artifacts (logs, pids, uploads, var)
