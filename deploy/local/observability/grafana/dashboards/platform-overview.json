      "targets": [
        {
          "expr": "avg by (gpu) (DCGM_FI_DEV_GPU_TEMP)",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "title": "GPU Temperature",
      "type": "timeseries"
