{
  "name": "memochat-qml",
  "version-string": "0.1.0",
  "builtin-baseline": "2fa7118fb2ce0c27ab73e08ab1991f4cb67af880",
  "dependencies": [
    "msquic"
  ],
  "default-features": [
    "server"
  ],
  "features": {
    "server": {
      "description": "Server-side dependencies",
      "dependencies": [
        {
          "name": "grpc",
          "features": [
            "codegen"
          ]
        },
        "protobuf",
        "hiredis",
        "glaze",
        "boost-asio",
        "boost-beast",
        "boost-filesystem",
        "spdlog",
        "librdkafka",
        "librabbitmq",
        "mongo-c-driver",
        "libpq",
        {
          "name": "nghttp2",
          "features": []
        },
        "openssl",
        "libsodium",
        {
          "name": "aws-sdk-cpp",
          "features": [
            "s3"
          ]
        },
        "benchmark",
        "gtest"
      ]
    },
    "http2": {
      "description": "HTTP/2 support via nghttp2",
      "dependencies": [
        "nghttp2"
      ]
    },
    "http3": {
      "description": "HTTP/3 and QUIC support via MsQuic",
      "dependencies": [
        "msquic",
        "openssl"
      ]
    },
    "webtransport-provider": {
      "description": "Experimental ChatServer WebTransport provider dependency via libwebsockets HTTP/3.",
      "dependencies": [
        "libwebsockets"
      ]
    }
  }
}
