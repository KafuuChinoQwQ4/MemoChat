{
  "name": "memochat-qml",
  "version-string": "0.1.0",
  "builtin-baseline": "2fa7118fb2ce0c27ab73e08ab1991f4cb67af880",
  "dependencies": [
    {
      "name": "msquic",
      "platform": "windows & !static"
    }
  ],
  "default-features": [
    "server"
  ],
  "features": {
    "server": {
      "description": "Server-side dependencies",
      "dependencies": [
        {
          "name": "grpc",
          "features": [
            "codegen"
          ]
        },
        "protobuf",
        "hiredis",
        "jsoncpp",
        "boost-asio",
        "boost-beast",
        "boost-filesystem",
        "boost-property-tree",
        "boost-uuid",
        "spdlog",
        "cppkafka",
        "librabbitmq",
        "mongo-cxx-driver",
        "libpq",
        "libpqxx",
        "drogon",
        "trantor",
        {
          "name": "ngtcp2",
          "features": []
        },
        {
          "name": "nghttp3",
          "features": []
        },
        "openssl",
        {
          "name": "aws-sdk-cpp",
          "features": [
            "s3"
          ]
        }
      ]
    },
    "http3": {
      "description": "HTTP/3 support via ngtcp2 + nghttp3",
      "dependencies": [
        "ngtcp2",
        "nghttp3",
        "openssl"
      ]
    }
  }
}
