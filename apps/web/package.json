{
  "name": "memochat-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "smoke:websocket": "node ../../tools/scripts/dev/browser_websocket_smoke.mjs",
    "smoke:webtransport": "node ../../tools/scripts/dev/browser_webtransport_smoke.mjs",
    "smoke:cross-transport": "node ../../tools/scripts/dev/browser_cross_transport_smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@tanstack/react-query": "5.83.0",
    "@tanstack/react-query-devtools": "5.83.0",
    "clsx": "2.1.1",
    "dexie": "4.0.11",
    "dexie-react-hooks": "1.1.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "7.6.3",
    "zustand": "5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react-swc": "3.10.2",
    "@vitest/ui": "3.2.4",
    "eslint": "9.30.1",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-boundaries": "5.0.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "jsdom": "^26.1.0",
    "msw": "2.10.3",
    "playwright": "^1.61.1",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  }
}
