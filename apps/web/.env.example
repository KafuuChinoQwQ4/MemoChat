# MemoChat Web — environment variables (.env.example)
# Copy to .env.local and fill in your values.

# Envoy gateway base URL (no trailing slash)
VITE_GATE_BASE_URL=https://localhost:8443

# Media CDN base URL
VITE_MEDIA_BASE_URL=https://localhost:8443

# AI service base URL
VITE_AI_BASE_URL=https://localhost:8443

# WebSocket-TCP bridge URL for real-time chat
VITE_WS_BRIDGE_URL=wss://localhost:8444/ws

# Set to "1" to prefer WebTransport when login response advertises it.
# WebSocket remains the fallback when both endpoints are present.
VITE_PREFER_WEBTRANSPORT=0

# Set to "1" to use MockChatTransport (no bridge required)
VITE_USE_MOCK_TRANSPORT=1

# Set to "1" to inject trace headers (X-Request-ID etc.)
VITE_TRACE_HEADERS=0
