# MemoChat Web — environment variables (.env.example)
# Copy to .env.local and fill in your values.

# Envoy gateway base URL (no trailing slash). Leave empty for same-origin Vite/Envoy proxying.
VITE_GATE_BASE_URL=

# Media CDN base URL
VITE_MEDIA_BASE_URL=https://localhost:8443

# AI service base URL
VITE_AI_BASE_URL=https://localhost:8443

# WebSocket chat URL for local real-time chat
VITE_WS_BRIDGE_URL=ws://localhost:8444/ws

# Set to "1" to prefer WebTransport when login response advertises it.
# WebSocket remains the fallback when both endpoints are present.
VITE_PREFER_WEBTRANSPORT=1

# Set to "1" to use MockChatTransport (no real chat transport required)
VITE_USE_MOCK_TRANSPORT=0

# Set to "1" to inject trace headers (X-Request-ID etc.)
VITE_TRACE_HEADERS=0
