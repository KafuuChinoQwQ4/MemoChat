# =============================================================================
# MemoChat 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# =============================================================================
# MSVC 编译器配置
# =============================================================================
# MSVC 版本号 (如 14.50.35717)
export MSVC_VERSION=14.50.35717
# Visual Studio 安装根目录
export VS_ROOT=
# VC Tools 路径
export VC_TOOLS_BIN=${VS_ROOT}/VC/Tools/MSVC/${MSVC_VERSION}/bin/Hostx64/x64
export VC_TOOLS_LIB=${VS_ROOT}/VC/Tools/MSVC/${MSVC_VERSION}/lib/x64
export VC_TOOLS_INCLUDE=${VS_ROOT}/VC/Tools/MSVC/${MSVC_VERSION}/include

# =============================================================================
# Windows SDK 配置
# =============================================================================
# Windows SDK 版本号 (如 10.0.28000.0)
export WINSDK_VERSION=10.0.28000.0
export WINSDK_ROOT=
export WINSDK_BIN=${WINSDK_ROOT}/bin/${WINSDK_VERSION}/x64
export WINSDK_LIB_UM=${WINSDK_ROOT}/Lib/${WINSDK_VERSION}/um/x64
export WINSDK_LIB_UCRT=${WINSDK_ROOT}/Lib/${WINSDK_VERSION}/ucrt/x64
export WINSDK_INCLUDE=${WINSDK_ROOT}/Include/${WINSDK_VERSION}

# =============================================================================
# CMake 配置
# =============================================================================
# CMake bin 目录
export CMAKE_BIN=${VS_ROOT}/Common7/IDE/CommonExtensions/Microsoft/CMake/CMake/bin
# Ninja 路径
export NINJA_PATH=

# =============================================================================
# vcpkg 配置
# =============================================================================
export VCPKG_ROOT=
export VCPKG_DOWNLOADS=${VCPKG_ROOT}/downloads
export VCPKG_BINARY_CACHE=${VCPKG_ROOT}/bincache
export VCPKG_TRIPLET=x64-windows

# =============================================================================
# 网络代理配置 (如不需要代理则留空)
# =============================================================================
export HTTP_PROXY=
export HTTPS_PROXY=
export NO_PROXY=

# =============================================================================
# 构建选项
# =============================================================================
# Ninja 并行任务数
export BUILD_JOBS=8
export BUILD_CONFIGURATION=Release

# =============================================================================
# 运行时部署目录
# =============================================================================
# 构建完成后自动部署服务的目标目录
# 默认为项目根目录下的 Memo_ops/runtime/services
export MEMOCHAT_RUNTIME_BASE=

# PostgreSQL — 主业务库
export MEMOCHAT_POSTGRES_PASSWD=

# PostgreSQL — 账号服务库
export MEMOCHAT_ACCOUNTPOSTGRES_PASSWD=

# Redis
export MEMOCHAT_REDIS_PASSWD=

# RabbitMQ
export MEMOCHAT_RABBITMQ_PASSWORD=

# MongoDB（完整 URI，含用户名密码）
# 格式：mongodb://<user>:<pass>@<host>:<port>/<db>
export MEMOCHAT_MONGO_URI=

# Chat auth HMAC secret（用于 login ticket 签名，生产环境必须修改）
# 默认 fail-closed：未注入 >=32 字节强随机密钥时，服务拒绝启动。
export MEMOCHAT_CHATAUTH_HMACSECRET=

# Refresh token keyed hash pepper（生产环境必须修改，至少 32 字节）
export MEMOCHAT_AUTH_REFRESH_PEPPER=

# 邮件验证服务（SMTP）
export MEMOCHAT_EMAIL_SMTPUSER=
export MEMOCHAT_EMAIL_SMTPPASS=

# Neo4j（AI 知识图谱）
export MEMOCHAT_NEO4J_PASSWORD=

# LiveKit（实时通话）
export MEMOCHAT_CALL_ACCESSKEY=
export MEMOCHAT_CALL_SECRETKEY=

# AI 服务内部 API key（各 AI Gateway 服务）
export MEMOCHAT_AI_INTERNAL_API_KEY=
export MEMOCHAT_AI_PROVIDER_ADMIN_KEY=

# R18 控制面与 Picacg 上游。普通客户端不得持有 source admin key。
export MEMOCHAT_R18SOURCEADMIN_ADMINKEY=
export MEMOCHAT_R18PICACG_ALLOWEDIMAGEHOSTS=
export MEMOCHAT_R18_PICACG_API_KEY=
export MEMOCHAT_R18_PICACG_HMAC_KEY=

# MinIO / 对象存储（MediaGateway 服务）
export MEMOCHAT_MINIO_ACCESSKEY=
export MEMOCHAT_MINIO_SECRETKEY=

# =============================================================================
# 安全运行时开关
# =============================================================================

# 是否信任 X-Forwarded-For / X-Real-IP 头用于登录频率限制 IP 桶。
# 只有在上游代理（Envoy）保证在转发前清除或覆盖这些头时才设置为 1。
# 默认：不信任（防止客户端伪造 IP 绕过速率限制）。
export MEMOCHAT_TRUST_FORWARDED_FOR=0

# 仅本地开发可显式放开 dev secret。
# 保持 0 或不设置时，空密钥、众所周知 dev 密钥、短密钥都会 fail-closed。
# 生产 / staging 不允许设置为 1。
export MEMOCHAT_ALLOW_DEV_SECRETS=0
# export MEMOCHAT_ALLOW_DEV_SECRETS=1   # 仅本地临时联调使用
