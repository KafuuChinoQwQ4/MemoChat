Config path: config.ini
[ChatAuth]
HmacSecret=memochat-dev-chat-secret
TicketTtlSec=20
[Cluster]
DiscoveryMode=static
Nodes=chatserver1,chatserver2,chatserver3,chatserver4
[FeatureFlags]
chat_group_kafka_primary=false
chat_group_kafka_shadow=false
chat_private_kafka_primary=false
chat_private_kafka_shadow=false
history_index_mongo_read=false
[GateServer]
Port=8080
[Kafka]
BatchNumMessages=1000
Brokers=127.0.0.1:19092
ClientId=memochat-chatserver3
ConsumeRetryMax=5
ConsumerGroup=memochat-chat-workers
EnableIdempotence=true
OutboxBatchSize=100
OutboxRetryBaseMs=1000
OutboxRetryMaxMs=30000
QueueBufferingMaxMs=10
SessionTimeoutMs=10000
TopicGroup=chat.group.v1
TopicGroupDlq=chat.group.dlq.v1
TopicPrivate=chat.private.v1
TopicPrivateDlq=chat.private.dlq.v1
[Log]
Dir=../../artifacts/logs/services/chatserver3
Env=local
Format=json
Level=info
MaxFiles=14
MaxSizeMB=100
Redact=true
RotateMode=daily
ToConsole=true
[Mongo]
Database=memochat
Enabled=true
GroupCollection=group_messages
PrivateCollection=private_messages
Uri=mongodb://memochat_app:123456@127.0.0.1:27017/memochat
[Postgres]
Database=memo_pg
Host=127.0.0.1
Passwd=123456
Port=5432
Schema=memo
SslMode=disable
User=memochat
[Quic]
Alpn=memochat-chat
CertFile=D:\MemoChat-Qml-Drogon\artifacts\certs\quic-dev\server-cert.pem
PfxFile=D:\MemoChat-Qml-Drogon\artifacts\certs\quic-dev\server-schannel3.pfx
PrivateKeyFile=D:\MemoChat-Qml-Drogon\artifacts\certs\quic-dev\server-key.pem
[RabbitMQ]
ExchangeDirect=memochat.direct
ExchangeDlx=memochat.dlx
Host=127.0.0.1
MaxRetries=5
Password=123456
Port=5672
PrefetchCount=50
RetryDelayMs=5000
Username=memochat
VHost=/
[Redis]
Host=127.0.0.1
Passwd=123456
Port=6379
[RelationBootstrapCache]
TtlSec=15
[Runtime]
AsyncEventBus=kafka
Role=hybrid
TaskBus=rabbitmq
[SelfServer]
Name=chatserver3
[Snowflake]
DatacenterId=1
WorkerId=3
[StatusServer]
Host=127.0.0.1
Port=50052
[Telemetry]
Enabled=true
ExportLogs=true
ExportMetrics=false
ExportTraces=true
OtlpEndpoint=http://127.0.0.1:9411/api/v2/spans
Protocol=zipkin-json
SampleRatio=1.0
ServiceName=ChatServer
ServiceNamespace=memochat
[VarifyServer]
Host=127.0.0.1
Port=50051
[chatserver1]
Enabled=true
Name=chatserver1
QuicHost=127.0.0.1
QuicPort=8190
RpcHost=127.0.0.1
RpcPort=50055
TcpHost=127.0.0.1
TcpPort=8090
[chatserver2]
Enabled=true
Name=chatserver2
QuicHost=127.0.0.1
QuicPort=8191
RpcHost=127.0.0.1
RpcPort=50056
TcpHost=127.0.0.1
TcpPort=8091
[chatserver3]
Enabled=true
Name=chatserver3
QuicHost=127.0.0.1
QuicPort=8192
RpcHost=127.0.0.1
RpcPort=50057
TcpHost=127.0.0.1
TcpPort=8092
[chatserver4]
Enabled=true
Name=chatserver4
QuicHost=127.0.0.1
QuicPort=8193
RpcHost=127.0.0.1
RpcPort=50058
TcpHost=127.0.0.1
TcpPort=8093
