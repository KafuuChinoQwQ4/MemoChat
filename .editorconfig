root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120

[*.{cpp,cxx,cc,h,hpp,hxx,hh,ipp,inl}]
indent_size = 4

[*.{qml,js,ts}]
indent_size = 4

[*.py]
indent_size = 4

[*.{cmake,ps1,sh}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
